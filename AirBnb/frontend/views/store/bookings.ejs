<%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-4xl">
    <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
      My Bookings
    </h2>

    <% if (bookings && bookings.length > 0) { %>
      <div class="space-y-4">
        <% bookings.forEach(booking => { %>
          <div class="border rounded-lg p-4 hover:shadow-md transition duration-300">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <h3 class="text-xl font-semibold text-gray-800 mb-2">
                  <%= booking.homeId?.houseName %>
                </h3>
                <p class="text-gray-600 text-sm mb-1">
                  <i class="fas fa-map-marker-alt mr-2"></i>
                  <%= booking.homeId?.location %>
                </p>
              </div>
              
              <div class="space-y-2 text-sm">
                <p>
                  <span class="font-semibold">Check-In:</span>
                  <%= new Date(booking.checkInDate).toLocaleDateString() %>
                </p>
                <p>
                  <span class="font-semibold">Check-Out:</span>
                  <%= new Date(booking.checkOutDate).toLocaleDateString() %>
                </p>
                <p>
                  <span class="font-semibold">Guests:</span>
                  <%= booking.numberOfGuests %>
                </p>
              </div>

              <div class="flex flex-col justify-between">
                <div>
                  <p class="text-gray-700 mb-1">
                    <span class="font-semibold">Total Price:</span>
                    <span class="text-lg font-bold text-green-600">$<%= booking.totalPrice %></span>
                  </p>
                  <p class="text-sm">
                    <span class="font-semibold">Status:</span>
                    <span class="<%= booking.status === 'confirmed' ? 'text-green-600' : booking.status === 'cancelled' ? 'text-red-600' : 'text-yellow-600' %>">
                      <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
                    </span>
                  </p>
                </div>
                <% if (booking.status !== 'cancelled') { %>
                  <form action="/bookings/<%= booking._id %>/cancel" method="POST" style="display: inline;">
                    <button type="submit" class="w-full bg-red-400 text-white py-2 rounded hover:bg-red-600 transition text-sm">
                      Cancel Booking
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="text-center py-12">
        <p class="text-2xl text-gray-600 mb-4">You have no bookings yet</p>
        <a href="/homes" class="inline-block bg-red-500 text-white py-2 px-6 rounded hover:bg-red-600 transition">
          Browse Homes
        </a>
      </div>
    <% } %>
  </main>
</body>
</html>
