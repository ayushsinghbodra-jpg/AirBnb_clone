<%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-2xl">
    <h2 class="text-3xl text-red-500 font-bold mb-6">
      Book <%= home.houseName %>
    </h2>

    <% if (errors && errors.length > 0) { %>
      <div class="mb-4 p-4 bg-red-100 border border-red-400 text-red-700 rounded">
        <ul>
          <% errors.forEach(error => { %>
            <li><%= error %></li>
          <% }); %>
        </ul>
      </div>
    <% } %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div>
        <img src="<%= home.photo %>" alt="<%= home.houseName %>" class="w-full h-64 object-cover rounded">
      </div>
      <div class="space-y-4">
        <div>
          <h3 class="text-xl font-semibold mb-2">Location</h3>
          <p class="text-gray-600"><%= home.location %></p>
        </div>
        <div>
          <h3 class="text-xl font-semibold mb-2">Price per Night</h3>
          <p class="text-2xl font-bold text-green-600">$<%= home.price %></p>
        </div>
        <div>
          <h3 class="text-xl font-semibold mb-2">Rating</h3>
          <div class="flex items-center">
            <span class="text-yellow-400 text-2xl">★</span>
            <span class="ml-2 text-lg"><%= home.rating %> / 5</span>
          </div>
        </div>
      </div>
    </div>

    <form method="POST" action="/book" class="space-y-4">
      <input type="hidden" name="homeId" value="<%= home._id %>">

      <div>
        <label for="checkInDate" class="block text-sm font-medium text-gray-700 mb-2">
          Check-In Date
        </label>
        <input 
          type="date" 
          id="checkInDate" 
          name="checkInDate" 
          required 
          class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
        />
      </div>

      <div>
        <label for="checkOutDate" class="block text-sm font-medium text-gray-700 mb-2">
          Check-Out Date
        </label>
        <input 
          type="date" 
          id="checkOutDate" 
          name="checkOutDate" 
          required 
          class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
        />
      </div>

      <div>
        <label for="numberOfGuests" class="block text-sm font-medium text-gray-700 mb-2">
          Number of Guests
        </label>
        <input 
          type="number" 
          id="numberOfGuests" 
          name="numberOfGuests" 
          min="1" 
          value="1"
          required 
          class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500"
        />
      </div>

      <div class="bg-gray-100 p-4 rounded-md">
        <p class="text-gray-700 text-sm">
          Total price will be calculated based on number of nights.
        </p>
      </div>

      <div class="flex gap-4 pt-4">
        <button 
          type="submit" 
          class="flex-1 bg-red-500 text-white font-bold py-3 rounded-md hover:bg-red-600 transition duration-300"
        >
          Confirm Booking
        </button>
        <a 
          href="/homes/<%= home._id %>" 
          class="flex-1 bg-gray-500 text-white font-bold py-3 rounded-md hover:bg-gray-600 transition duration-300 text-center"
        >
          Cancel
        </a>
      </div>
    </form>
  </main>
</body>
</html>
